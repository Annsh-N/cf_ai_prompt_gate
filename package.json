{
  "name": "promptgate",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts tests/worker",
    "check": "npm run typecheck && npm run test && npm run test:worker",
    "bench": "tsx scripts/benchmark.ts",
    "bench:live": "PROMPTGATE_LIVE_AI=1 tsx scripts/benchmark.ts",
    "screenshots": "node scripts/generate-screenshots.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260715.1",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
